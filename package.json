{
  "name": "dependabot-policy-enforcer-action",
  "version": "1.0.0",
  "description": "A reusable GitHub Action that validates Dependabot policy compliance via HMAC-signed API call",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "esbuild src/main.ts --bundle --platform=node --target=node24 --outfile=dist/index.cjs --format=cjs",
    "test": "vitest",
    "all": "yarn build && yarn test --typecheck --run",
    "hmac-helper": "tsx scripts/hmac-helper.ts"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/http-client": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "esbuild": "^0.25.0",
    "tsx": "^4.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "packageManager": "yarn@4.6.0",
  "engines": {
    "node": ">=24.0.0"
  }
}
